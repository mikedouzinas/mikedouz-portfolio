# OpenAI API Key (Required for Custom RAG version)
# Get from: https://platform.openai.com/api-keys
# Used for: Iris AI responses, intent detection, embeddings
OPENAI_API_KEY=sk-...

# Anthropic API Key (Required for Claude Direct version)
# Get from: https://console.anthropic.com/
# Used for: Simple Claude-based Iris implementation with prompt caching
ANTHROPIC_API_KEY=sk-ant-...

# RESEND API KEY FOR SENDING EMAILS
RESEND_API_KEY=

# Upstash Redis (Required for production caching)
# Get from: https://console.upstash.com/
# Used for: Caching Iris responses (1-hour TTL)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Supabase (Required for analytics and inbox)
# Get from: https://app.supabase.com/project/_/settings/api
# Used for: Query analytics, inbox messages
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# GitHub Personal Access Token (Optional)
# Get from: https://github.com/settings/tokens
# Used for: Fetching recent GitHub activity in Iris responses
# Permissions needed: public_repo (read-only)
GITHUB_TOKEN=ghp_...

# Google Analytics 4 (Optional)
# Get from: https://analytics.google.com/ → Admin → Data Streams → your stream → Measurement ID
# Used for: Page views, user demographics, custom event tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Spotify API (Optional — used for album art and preview URL enrichment)
# Get from: https://developer.spotify.com/dashboard → your app → Settings
# Used for: scripts/analyze_spotify.ts enrichment step
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Environment
NODE_ENV=development

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
